{
  "name": "ratan-jewellers-backend",
  "version": "1.0.0",
  "description": "Ratan Jewellers Backend API - Node.js + MongoDB",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
